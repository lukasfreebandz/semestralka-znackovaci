{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "name",
    "edition",
    "description",
    "summary",
    "startDate",
    "endDate",
    "location",
    "tickets",
    "links"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^F\\d{3}$"
    },
    "name": {
      "type": "string"
    },
    "edition": {
      "type": "integer",
      "minimum": 1
    },
    "description": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "endDate": {
      "type": "string",
      "format": "date"
    },
    "location": {
      "type": "string"
    },
    "tickets": {
      "type": "object",
      "required": [
        "currency",
        "presalePrice",
        "regularPrice",
        "url"
      ],
      "properties": {
        "currency": {
          "type": "string"
        },
        "presalePrice": {
          "type": "integer",
          "minimum": 1
        },
        "regularPrice": {
          "type": "integer",
          "minimum": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "rel",
          "href"
        ],
        "properties": {
          "rel": {
            "type": "string"
          },
          "href": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  }
}
